OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Supabase is optional for the current private local MVP.
# If these are unset, the app writes to .data/boardsmith.json.
NEXT_PUBLIC_SUPABASE_URL=
# Server-only. Required for the current private no-auth Supabase smoke.
SUPABASE_SERVICE_ROLE_KEY=
# Reserved for future authenticated/client flows; do not rely on this alone for the private MVP smoke.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional local fallback override, useful for isolated tests.
BOARDSMITH_DATA_FILE=

# Optional private MVP gate. When set, app routes require this password before use.
# Leave blank for local-only development without the access gate.
# Do not deploy to a public URL with real OpenAI/Supabase keys unless this is set
# or stronger access control is in place.
BOARDSMITH_ACCESS_PASSWORD=

# Optional hosted smoke automation only. Copy these names into an ignored
# .env.hosted-smoke.local file for `npm run smoke:hosted`.
# Keep these unset for normal local use. Do not commit real hosted URLs,
# Vercel bypass secrets, or access passwords.
BOARDSMITH_HOSTED_SMOKE_URL=
VERCEL_AUTOMATION_BYPASS_SECRET=
BOARDSMITH_HOSTED_SMOKE_PATHS=/,/projects
# Optional local authenticated session cookie file. This file must stay ignored.
BOARDSMITH_HOSTED_SMOKE_STORAGE_STATE=.auth/hosted-smoke-storage-state.json
# Optional future browser/session smoke only. Use a dedicated non-critical
# smoke account if the hosted login layer supports scripted account login.
# If hosted auth is email-link or OAuth-only, use an authorized local browser
# session for UI smoke instead of storing personal credentials.
BOARDSMITH_HOSTED_SMOKE_EMAIL=
BOARDSMITH_HOSTED_SMOKE_PASSWORD=
